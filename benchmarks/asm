#!/usr/bin/env bash
# Usage: asm [--compiler g++] [--flags "-O3 -march=native"] <file>
# Output: demangled assembly on stdout

COMPILER=g++
FLAGS="-O3 -march=native"

while [[ $# -gt 0 ]]; do
    case $1 in
        --compiler) COMPILER="$2"; shift 2 ;;
        --flags)    FLAGS="$2";    shift 2 ;;
        *)          FILE="$1";     shift   ;;
    esac
done

if [[ -z "$FILE" ]]; then
    echo "Usage: asm [--compiler g++] [--flags \"-O3 -march=native\"] <file>" >&2
    exit 1
fi

$COMPILER $FLAGS \
    -S \
    -fno-asynchronous-unwind-tables \
    -fno-exceptions \
    -o - \
    "$FILE" 2>&1 | c++filt
